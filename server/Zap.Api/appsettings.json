{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=zap_dev;Username=postgres;Password=postgres"
  },
  "Observability": {
    "SlowRequestThresholdMs": 1000
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "Zap.Api"
    }
  },
  "AllowedHosts": "*"
}
